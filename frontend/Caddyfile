:80 {
	###################################################################
	# Server config
	###################################################################

	root * /var/empty
	encode zstd gzip

	log {
		output file /logs/caddy-access.json
		format json {
			time_format iso8601
		}
		format filter {
			request>headers delete
			resp_headers delete
		}
	}

	###################################################################
	# Common routes (work for all hostnames)
	###################################################################

	handle_path /files/* {
		root * /media/processed
		file_server {
			precompressed
		}
		header Cache-Control "public, max-age=604800, immutable"
	}

	handle /api/mqtt {
		reverse_proxy mqtt:9001
	}

	handle /api/lint/* {
		reverse_proxy lint:3000
	}

	handle /api/room/* {
		reverse_proxy api_queue:8000
	}

	handle /api/misc/* {
		reverse_proxy api_queue:8000
	}

	handle /api/edit/* {
		reverse_proxy api_edit:8000
	}

	handle /api/upload/* {
		reverse_proxy upload:8000
	}

	###################################################################
	# Application-specific routes
	###################################################################

	handle_path /logs/* {
		root * /logs
		file_server browse
	}

	handle_path /data/queue/* {
		root * /data/queue
		file_server browse
	}

	handle_path /tools/* {
		root * /static/tools
		file_server
	}

	handle_path /browser3/* {
		reverse_proxy browser3
	}

	handle_path /player3/* {
		reverse_proxy player3
	}

	handle_path /upload/* {
		reverse_proxy upload:8000
	}

	handle_path /syncthing/* {
		reverse_proxy syncthing:8384
	}

	handle_path /* {
		@needsSlash {
			path_regexp top ^/[^/]+$
			not path */
			not file
		}
		redir @needsSlash {path}/
		respond "Not Found" 404
	}
}
