{
    "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
    "vcs": { "enabled": true, "clientKind": "git", "useIgnoreFile": true },
    "files": {
        "includes": ["**", "!src/types.ts", "!src/schemas.ts", "!!dist"]
    },
    "assist": { "actions": { "source": { "organizeImports": "on" } } },
    "formatter": {
        "indentStyle": "space",
        "indentWidth": 4
    },
    "linter": {
        "rules": {
            "a11y": {
                "noAutofocus": "off",
                "useMediaCaption": "off",
                "useKeyWithClickEvents": "off",
                "noStaticElementInteractions": "off"
            },
            "suspicious": {
                "noArrayIndexKey": "off",
                "noExplicitAny": "off",
                "noExportsInTest": "off",
                "noDocumentCookie": "off",
                "noPrototypeBuiltins": "off"
            },
            "complexity": {
                "noImportantStyles": "off",
                "useLiteralKeys": "off"
            },
            "correctness": {
                "useExhaustiveDependencies": "off"
            }
        }
    },
    "javascript": {
        "formatter": {
            "trailingCommas": "all",
            "quoteStyle": "double"
        }
    },
    "overrides": [
        {
            "includes": ["src/**/*.stories.tsx"],
            "linter": {
                "rules": {
                    "a11y": {
                        "recommended": false
                    }
                }
            }
        }
    ]
}
