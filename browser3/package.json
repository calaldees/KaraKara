{
    "name": "browser3",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "generate-types": "openapi-typescript ../openapi/components.yaml -o src/types.ts --root-types --root-types-no-schema-prefix",
        "generate-schemas": "node ../openapi/extract-schemas.js",
        "serve": "rsbuild dev",
        "build": "tsc -b && rsbuild build",
        "cypress": "npx cypress open",
        "format": "biome format --write .",
        "preview": "rsbuild preview",
        "lint": "biome lint .",
        "check": "biome check .",
        "test": "vitest",
        "test-once": "vitest run",
        "bench": "vitest bench",
        "storybook": "storybook dev -p 6006 --no-open"
    },
    "dependencies": {
        "@fortawesome/free-solid-svg-icons": "^7.0.1",
        "@mantine/hooks": "^9.0",
        "@rjsf/core": "^6.5.1",
        "@rjsf/utils": "^6.4.1",
        "@rjsf/validator-ajv8": "^6.5.1",
        "@shish2k/react-faicon": "^0.1",
        "@shish2k/react-mqtt": "^0.1",
        "@shish2k/react-use-servertime": "^0.1",
        "@ungap/global-this": "^0.4.4",
        "abortcontroller-polyfill": "^1.7.8",
        "qrcode.react": "^4.2.0",
        "react": "^19.2.5",
        "react-dom": "^19.2.5",
        "react-router-dom": "^7.14.1",
        "react-to-print": "^3.1.1",
        "usehooks-ts": "^3.1.1"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.12",
        "@rsbuild/core": "^1.1.13",
        "@rsbuild/plugin-react": "^1.1.1",
        "@rsbuild/plugin-sass": "^1.1.1",
        "@types/jsdom": "^28.0.1",
        "@types/node": "^25.6",
        "@types/react": "^19.0.10",
        "@types/react-dom": "^19.0.4",
        "cypress": "^15.14.0",
        "js-yaml": "^4.1.0",
        "jsdom": "^29.0.2",
        "openapi-typescript": "^7.4.4",
        "storybook": "^10.3.5",
        "storybook-react-rsbuild": "^3.3.3",
        "typescript": "^5.9.3",
        "vitest": "^4.1.4"
    }
}
