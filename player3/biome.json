{
    "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
    "vcs": { "enabled": true, "clientKind": "git", "useIgnoreFile": true },
    "files": {
        "includes": ["**", "!src/types.ts", "!src/schemas.ts", "!!dist"]
    },
    "assist": { "actions": { "source": { "organizeImports": "on" } } },
    "formatter": {
        "indentStyle": "space",
        "indentWidth": 4
    },
    "linter": {
        "rules": {
            "a11y": {
                "recommended": false
            },
            "suspicious": {
                "noExplicitAny": "off"
            },
            "correctness": {
                "useExhaustiveDependencies": "off"
            },
            "complexity": {
                "useLiteralKeys": "off"
            }
        }
    },
    "javascript": {
        "formatter": {
            "trailingCommas": "all",
            "quoteStyle": "double"
        }
    }
}
