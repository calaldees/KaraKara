{
    "name": "player3",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "generate-types": "openapi-typescript ../openapi/components.yaml -o src/types.ts --root-types --root-types-no-schema-prefix",
        "generate-schemas": "node ../openapi/extract-schemas.js",
        "serve": "rsbuild dev",
        "build": "tsc -b && rsbuild build",
        "cypress": "npx cypress open",
        "format": "biome format --write .",
        "preview": "rsbuild preview",
        "lint": "biome lint .",
        "check": "biome check .",
        "test": "vitest",
        "test-once": "vitest run"
    },
    "dependencies": {
        "@fortawesome/free-solid-svg-icons": "^7.2.0",
        "@mantine/hooks": "^9.1",
        "@react-three/drei": "^10.0.4",
        "@react-three/fiber": "^9.6.1",
        "@shish2k/react-faicon": "^0.1.0",
        "@shish2k/react-mqtt": "^0.1.0",
        "@shish2k/react-use-servertime": "^0.1.0",
        "react": "^19.2.5",
        "react-dom": "^19.2.5",
        "react-router-dom": "^7.14.2",
        "react-screen-wake-lock": "^3.0.4",
        "three": "^0.184.0",
        "tinyduration": "^3.4.1",
        "usehooks-ts": "^3.1.1"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.13",
        "@rsbuild/core": "^1.1.13",
        "@rsbuild/plugin-react": "^1.1.1",
        "@rsbuild/plugin-sass": "^1.5.2",
        "@types/node": "^25.6",
        "@types/react": "^19.0.10",
        "@types/react-dom": "^19.0.4",
        "@types/three": "^0.184.0",
        "js-yaml": "^4.1.0",
        "jsdom": "^29.1.1",
        "openapi-typescript": "^7.4.4",
        "timezone-mock": "^1.3.6",
        "typescript": "^6.0.3",
        "vitest": "^4.1.5"
    }
}
