{
    "name": "player3",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "generate-types": "openapi-typescript ../openapi/openapi.yaml -o src/types.ts --root-types --root-types-no-schema-prefix",
        "generate-schemas": "node ../openapi/extract-schemas.js",
        "serve": "rsbuild dev",
        "build": "tsc -b && rsbuild build",
        "cypress": "npx cypress open",
        "format": "prettier --write .",
        "preview": "rsbuild preview",
        "lint": "eslint src",
        "test": "vitest",
        "test-once": "vitest run"
    },
    "dependencies": {
        "@fortawesome/free-solid-svg-icons": "^7.2.0",
        "@mantine/hooks": "^8.3.18",
        "@react-three/drei": "^10.0.4",
        "@react-three/fiber": "^9.1.0",
        "@shish2k/react-faicon": "^0.0.2",
        "@shish2k/react-mqtt": "^0.0.5",
        "@shish2k/react-use-servertime": "^0.0.6",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "react-router-dom": "^7.12.0",
        "react-screen-wake-lock": "^3.0.4",
        "three": "^0.181.0",
        "tinyduration": "^3.4.1",
        "usehooks-ts": "^3.1.1"
    },
    "devDependencies": {
        "@rsbuild/core": "^1.1.13",
        "@rsbuild/plugin-react": "^1.1.1",
        "@rsbuild/plugin-sass": "^1.1.1",
        "@types/node": "^24.5.2",
        "@types/react": "^19.0.10",
        "@types/react-dom": "^19.0.4",
        "@types/three": "^0.181.0",
        "eslint": "^9.21.0",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-dom": "^2.3.5",
        "eslint-plugin-react-hooks": "^7.0.1",
        "eslint-plugin-react-refresh": "^0.4.19",
        "eslint-plugin-react-x": "^2.3.5",
        "js-yaml": "^4.1.0",
        "jsdom": "^29.0.1",
        "openapi-typescript": "^7.4.4",
        "prettier": "^3.6",
        "prettier-plugin-organize-imports": "^4.3.0",
        "timezone-mock": "^1.3.6",
        "typescript": "^5.9.2",
        "typescript-eslint": "^8.24.1",
        "vitest": "^4.0.8"
    },
    "prettier": {
        "tabWidth": 4,
        "trailingComma": "all",
        "plugins": [
            "prettier-plugin-organize-imports"
        ]
    }
}
